---
const whatsappHref = 'https://wa.me/525644166523';
---

<a
	class="whatsapp-button"
	href={whatsappHref}
	target="_blank"
	rel="noopener noreferrer"
	aria-label="Open WhatsApp chat with Elite Ride Mexico"
>
	<svg viewBox="0 0 32 32" aria-hidden="true" focusable="false">
		<path
			fill="currentColor"
			d="M16.04 3.2c-7.06 0-12.8 5.73-12.8 12.78 0 2.25.59 4.45 1.72 6.38L3.13 29l6.81-1.79a12.75 12.75 0 0 0 6.1 1.55h.01c7.05 0 12.79-5.73 12.8-12.78A12.72 12.72 0 0 0 16.04 3.2Zm0 23.4h-.01c-1.94 0-3.84-.52-5.5-1.5l-.39-.23-4.04 1.06 1.08-3.94-.25-.4a10.57 10.57 0 0 1-1.62-5.61c0-5.9 4.81-10.7 10.73-10.7 2.86 0 5.55 1.11 7.58 3.13a10.63 10.63 0 0 1 3.14 7.57c0 5.9-4.81 10.7-10.72 10.7Zm5.88-8.02c-.32-.16-1.91-.94-2.21-1.05-.3-.11-.51-.16-.73.16-.22.32-.84 1.05-1.03 1.26-.19.22-.38.24-.7.08-.32-.16-1.36-.5-2.59-1.6-.96-.85-1.6-1.9-1.79-2.22-.19-.32-.02-.5.14-.66.15-.14.32-.38.49-.57.16-.19.22-.32.32-.54.11-.22.05-.4-.03-.57-.08-.16-.73-1.76-1-2.41-.26-.63-.53-.54-.73-.55h-.62c-.22 0-.57.08-.86.4-.3.32-1.14 1.11-1.14 2.71s1.16 3.14 1.33 3.36c.16.22 2.29 3.49 5.55 4.89.78.34 1.38.54 1.85.69.78.25 1.49.21 2.05.13.62-.09 1.91-.78 2.18-1.53.27-.75.27-1.4.19-1.53-.08-.14-.3-.22-.62-.38Z"
		/>
	</svg>
	<span>WhatsApp</span>
</a>

<style>
	.whatsapp-button {
		position: fixed;
		right: 22px;
		bottom: 188px;
		z-index: 2147483645;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 9px;
		min-height: 54px;
		padding: 0 16px;
		border-radius: 999px;
		background: #25d366;
		color: #06150b;
		font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
		font-size: 15px;
		font-weight: 900;
		line-height: 1;
		text-decoration: none;
		box-shadow: 0 16px 44px rgba(0, 0, 0, 0.32);
		transition:
			transform 160ms ease,
			background-color 160ms ease;
	}

	.whatsapp-button:hover,
	.whatsapp-button:focus-visible {
		background: #2fe675;
		color: #06150b;
		transform: translateY(-2px);
	}

	.whatsapp-button:focus-visible {
		outline: 3px solid rgba(255, 255, 255, 0.9);
		outline-offset: 3px;
	}

	.whatsapp-button svg {
		width: 25px;
		height: 25px;
		flex: 0 0 auto;
	}

	@media (max-width: 560px) {
		.whatsapp-button {
			right: 14px;
			bottom: 176px;
			min-height: 50px;
			padding: 0 14px;
			font-size: 14px;
		}
	}
</style>
