---
import { footerKeywordsEn, footerKeywordsEs } from '../data/worldCupKeywords';

interface Props {
	lang?: 'en' | 'es' | 'fr';
}

const { lang = 'en' } = Astro.props;
const keywords = lang === 'es' ? footerKeywordsEs : footerKeywordsEn;
const keywordText = keywords.join(' · ');
const ariaLabel =
	lang === 'es'
		? 'Palabras clave de transporte privado en México'
		: lang === 'fr'
			? 'Mots-clés SEO de transport privé au Mexique'
		: 'Private transportation SEO keywords in Mexico';
---

<section class="seo-footer-keywords" aria-label={ariaLabel}>
	<p class="seo-footer-keywords__text">{keywordText}</p>
</section>
