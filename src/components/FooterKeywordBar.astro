---
import { worldCupKeywordsEn, worldCupKeywordsEs } from '../data/worldCupKeywords';

interface Props {
	lang?: 'en' | 'es';
}

const { lang = 'en' } = Astro.props;
const keywords = (lang === 'es' ? worldCupKeywordsEs : worldCupKeywordsEn).join(' · ');
const ariaLabel =
	lang === 'es'
		? 'Búsquedas relacionadas con Mundial 2026 en México'
		: 'World Cup 2026 transportation searches in Mexico';
---

<section class="seo-footer-keywords" aria-label={ariaLabel}>
	<div class="seo-footer-keywords__inner">
		<p class="seo-footer-keywords__line">{keywords}</p>
	</div>
</section>
