---
const siteCode = 'eliteridemexico';
---

<div id="sofia-chat" data-site-code={siteCode}></div>

<style is:inline>
  #sofia-chat {
    position: fixed;
    right: 22px;
    bottom: 22px;
    z-index: 2147483646;
    font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
  }

  #sofia-chat * {
    box-sizing: border-box;
  }

  .sofia-panel {
    width: min(400px, calc(100vw - 28px));
    height: min(660px, calc(100vh - 110px));
    margin-bottom: 14px;
    display: none;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid rgba(214, 178, 100, 0.42);
    border-radius: 18px;
    background: #090909;
    color: #fff;
    box-shadow: 0 28px 90px rgba(0, 0, 0, 0.58);
  }

  .sofia-panel.is-open {
    display: flex;
  }

  .sofia-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 18px;
    background: linear-gradient(135deg, rgba(214, 178, 100, 0.24), rgba(255, 255, 255, 0.07)), #111;
    border-bottom: 1px solid rgba(214, 178, 100, 0.34);
  }

  .sofia-title {
    margin: 0;
    color: #d6b264;
    font-size: 18px;
    font-weight: 900;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .sofia-status {
    margin: 4px 0 0;
    color: rgba(255, 255, 255, 0.68);
    font-size: 13px;
  }

  .sofia-close,
  .sofia-toggle,
  .sofia-teaser,
  .sofia-lead button,
  .sofia-composer button {
    border: 0;
    cursor: pointer;
    font: inherit;
  }

  .sofia-close {
    width: 38px;
    height: 38px;
    border-radius: 12px;
    background: rgba(214, 178, 100, 0.24);
    color: #fff;
    font-weight: 900;
  }

  .sofia-messages {
    flex: 1;
    min-height: 180px;
    overflow-y: auto;
    padding: 16px;
    background: linear-gradient(rgba(214, 178, 100, 0.06) 1px, transparent 1px), #0d0d0d;
    background-size: 100% 42px;
  }

  .sofia-message {
    width: fit-content;
    max-width: 88%;
    margin: 0 0 10px;
    padding: 11px 13px;
    border-radius: 16px;
    font-size: 14px;
    line-height: 1.45;
    white-space: pre-wrap;
  }

  .sofia-message.assistant {
    background: rgba(255, 255, 255, 0.09);
    color: #f7f2e8;
  }

  .sofia-message.user {
    margin-left: auto;
    background: #d6b264;
    color: #080808;
  }

  .sofia-lead {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 9px;
    padding: 14px;
    background: #111;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .sofia-lead p,
  .sofia-lead button {
    grid-column: 1 / -1;
  }

  .sofia-lead p {
    margin: 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 13px;
    line-height: 1.4;
  }

  .sofia-lead input,
  .sofia-composer input {
    width: 100%;
    min-width: 0;
    border: 1px solid rgba(214, 178, 100, 0.28);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    font: inherit;
    font-size: 14px;
    outline: none;
  }

  .sofia-lead input {
    padding: 11px;
  }

  .sofia-lead input::placeholder,
  .sofia-composer input::placeholder {
    color: rgba(255, 255, 255, 0.55);
  }

  .sofia-lead button,
  .sofia-composer button,
  .sofia-toggle {
    background: #d6b264;
    color: #080808;
    font-weight: 900;
  }

  .sofia-lead button {
    padding: 12px 14px;
    border-radius: 12px;
  }

  .sofia-composer {
    display: grid;
    grid-template-columns: 1fr 52px;
    gap: 9px;
    padding: 14px;
    background: #090909;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .sofia-composer input {
    padding: 12px 13px;
  }

  .sofia-composer button {
    border-radius: 12px;
    font-size: 20px;
  }

  .sofia-composer button:disabled,
  .sofia-lead button:disabled,
  .sofia-composer input:disabled {
    opacity: 0.58;
    cursor: not-allowed;
  }

  .sofia-closed {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
  }

  .sofia-teaser {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border: 1px solid rgba(214, 178, 100, 0.42);
    border-radius: 999px;
    background: #0b0b0b;
    color: #fff;
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.36);
  }

  .sofia-avatar {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: #d6b264;
    color: #080808;
    font-weight: 900;
  }

  .sofia-toggle {
    min-width: 68px;
    height: 68px;
    padding: 0 14px;
    border-radius: 999px;
    box-shadow: 0 16px 44px rgba(0, 0, 0, 0.42);
  }

  @media (max-width: 560px) {
    #sofia-chat {
      right: 14px;
      bottom: 14px;
    }

    .sofia-lead {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  (() => {
    const root = document.getElementById('sofia-chat');
    if (!root || root.dataset.ready === 'true') return;
    root.dataset.ready = 'true';

    const siteCode = root.dataset.siteCode || 'eliteridemexico';
    const leadEndpoint = 'https://www.o7digital.com/api/o7-lead';
    const chatEndpoint = 'https://www.o7digital.com/api/o7-chat';

    const copy = {
      es: {
        title: 'Sofia',
        status: 'Asistente Elite Ride Mexico',
        online: 'En linea',
        teaser: 'Necesitas transporte?',
        open: 'Abrir chat',
        close: 'Cerrar chat',
        welcome: 'Hola, soy Sofia. En que puedo ayudarte con tu transporte privado?',
        leadIntro: 'Deja tus datos para que un asesor de Elite Ride Mexico pueda contactarte.',
        firstName: 'Nombre',
        lastName: 'Apellido',
        email: 'Email',
        phone: 'Telefono',
        submitLead: 'Enviar datos',
        leadThanks: 'Gracias. Tus datos fueron enviados y un asesor te contactara pronto.',
        placeholder: 'Escribe tu pregunta...',
        send: 'Enviar',
        error: 'No pude enviar el mensaje. Intenta de nuevo o contacta directamente a Elite Ride Mexico.',
      },
      en: {
        title: 'Sofia',
        status: 'Elite Ride Mexico Assistant',
        online: 'Online',
        teaser: 'Need a ride?',
        open: 'Open chat',
        close: 'Close chat',
        welcome: 'Hello, I am Sofia. How can I help with your private transportation?',
        leadIntro: 'Leave your details so an Elite Ride Mexico advisor can contact you.',
        firstName: 'First name',
        lastName: 'Last name',
        email: 'Email',
        phone: 'Phone',
        submitLead: 'Send details',
        leadThanks: 'Thanks. Your details were sent and an advisor will contact you soon.',
        placeholder: 'Write your question...',
        send: 'Send',
        error: 'I could not send the message. Please try again or contact Elite Ride Mexico directly.',
      },
      fr: {
        title: 'Sofia',
        status: 'Assistante Elite Ride Mexico',
        online: 'En ligne',
        teaser: 'Besoin de transport ?',
        open: 'Ouvrir le chat',
        close: 'Fermer le chat',
        welcome: 'Bonjour, je suis Sofia. Comment puis-je vous aider pour votre transport prive ?',
        leadIntro: "Laissez vos coordonnees pour qu'un conseiller Elite Ride Mexico puisse vous contacter.",
        firstName: 'Prenom',
        lastName: 'Nom',
        email: 'Email',
        phone: 'Telephone',
        submitLead: 'Envoyer',
        leadThanks: 'Merci. Vos coordonnees ont ete envoyees et un conseiller vous contactera rapidement.',
        placeholder: 'Ecrivez votre question...',
        send: 'Envoyer',
        error: "Je n'ai pas pu envoyer le message. Reessayez ou contactez directement Elite Ride Mexico.",
      },
    };

    const getLanguage = () => {
      const lang = (document.documentElement.lang || '').toLowerCase();
      const path = window.location.pathname;
      if (lang.startsWith('fr') || path.startsWith('/fr')) return 'fr';
      if (lang.startsWith('es') || path.startsWith('/es')) return 'es';
      return 'en';
    };

    const detectMessageLanguage = (message, fallbackLanguage) => {
      const value = (message || '').toLowerCase();
      if (/\b(hola|gracias|quiero|precio|precios|cotizacion|traslado|aeropuerto|chofer|privado|camioneta|blindado|cancun|cdmx|guadalajara|puerto vallarta)\b/.test(value)) return 'es';
      if (/\b(bonjour|merci|prix|devis|transfert|aeroport|chauffeur|prive|vehicule|blindee|cancun|mexico|guadalajara|puerto vallarta)\b/.test(value)) return 'fr';
      if (/\b(hello|thanks|price|quote|transfer|airport|chauffeur|private|suv|armored|cancun|mexico city|guadalajara|puerto vallarta)\b/.test(value)) return 'en';
      return fallbackLanguage;
    };

    const lang = getLanguage();
    const t = copy[lang] || copy.en;
    let isOpen = false;
    let isLoading = false;
    let leadSent = false;
    let messages = [{ role: 'assistant', content: t.welcome }];
    let lead = { firstName: '', lastName: '', email: '', phone: '' };

    const escapeHtml = (value) => String(value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');

    const transcript = () => messages.map((message) => `${message.role}: ${message.content}`).join('\n');

    const renderMessages = () => messages.map((message) => (
      `<div class="sofia-message ${message.role}">${escapeHtml(message.content)}</div>`
    )).join('') + (isLoading ? '<div class="sofia-message assistant">...</div>' : '');

    const render = () => {
      root.innerHTML = `
        <section class="sofia-panel ${isOpen ? 'is-open' : ''}" aria-label="${escapeHtml(t.status)}">
          <header class="sofia-header">
            <div>
              <p class="sofia-title">${escapeHtml(t.title)}</p>
              <p class="sofia-status">${escapeHtml(t.status)} · ${escapeHtml(t.online)}</p>
            </div>
            <button type="button" class="sofia-close" aria-label="${escapeHtml(t.close)}">x</button>
          </header>
          <div class="sofia-messages">${renderMessages()}</div>
          ${leadSent ? '' : `
            <form class="sofia-lead">
              <p>${escapeHtml(t.leadIntro)}</p>
              <input required name="firstName" placeholder="${escapeHtml(t.firstName)}" value="${escapeHtml(lead.firstName)}" />
              <input required name="lastName" placeholder="${escapeHtml(t.lastName)}" value="${escapeHtml(lead.lastName)}" />
              <input required type="email" name="email" placeholder="${escapeHtml(t.email)}" value="${escapeHtml(lead.email)}" />
              <input required type="tel" name="phone" placeholder="${escapeHtml(t.phone)}" value="${escapeHtml(lead.phone)}" />
              <button type="submit" ${isLoading ? 'disabled' : ''}>${escapeHtml(t.submitLead)}</button>
            </form>
          `}
          <div class="sofia-composer">
            <input class="sofia-input" value="" ${!leadSent || isLoading ? 'disabled' : ''} placeholder="${escapeHtml(t.placeholder)}" />
            <button type="button" class="sofia-send" ${!leadSent || isLoading ? 'disabled' : ''} aria-label="${escapeHtml(t.send)}">&gt;</button>
          </div>
        </section>
        <div class="sofia-closed">
          ${isOpen ? '' : `
            <button type="button" class="sofia-teaser">
              <span class="sofia-avatar">S</span>
              <span>${escapeHtml(t.teaser)}</span>
            </button>
          `}
          <button type="button" class="sofia-toggle" aria-label="${escapeHtml(isOpen ? t.close : t.open)}">${isOpen ? 'x' : 'Sofia'}</button>
        </div>
      `;
      bindEvents();
      const messagesNode = root.querySelector('.sofia-messages');
      if (messagesNode) messagesNode.scrollTop = messagesNode.scrollHeight;
    };

    const saveLeadFields = () => {
      const form = root.querySelector('.sofia-lead');
      if (!form) return;
      lead = {
        firstName: form.firstName?.value || lead.firstName,
        lastName: form.lastName?.value || lead.lastName,
        email: form.email?.value || lead.email,
        phone: form.phone?.value || lead.phone,
      };
    };

    const submitLead = async (event) => {
      event.preventDefault();
      if (isLoading) return;
      saveLeadFields();
      if (!lead.firstName.trim() || !lead.lastName.trim() || !lead.email.trim() || !lead.phone.trim()) return;

      isLoading = true;
      render();
      try {
        const response = await fetch(leadEndpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            firstName: lead.firstName.trim(),
            lastName: lead.lastName.trim(),
            email: lead.email.trim(),
            phone: lead.phone.trim(),
            source: 'Chat Sofia Elite Ride Mexico',
            language: lang,
            siteCode,
            message: `Lead Chat Sofia Elite Ride Mexico (${lang}, ${siteCode})\n\n${transcript()}`,
          }),
        });
        if (!response.ok) throw new Error('Lead delivery failed');
        leadSent = true;
        messages.push({ role: 'assistant', content: t.leadThanks });
      } catch (_error) {
        messages.push({ role: 'assistant', content: t.error });
      } finally {
        isLoading = false;
        render();
      }
    };

    const sendMessage = async () => {
      const input = root.querySelector('.sofia-input');
      const message = input?.value?.trim() || '';
      if (!message || isLoading || !leadSent) return;
      const messageLanguage = detectMessageLanguage(message, lang);

      messages.push({ role: 'user', content: message });
      isLoading = true;
      render();
      try {
        const response = await fetch(chatEndpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message, language: messageLanguage, siteCode }),
        });
        const data = await response.json();
        messages.push({ role: 'assistant', content: data.reply || t.error });
      } catch (_error) {
        messages.push({ role: 'assistant', content: t.error });
      } finally {
        isLoading = false;
        render();
      }
    };

    const bindEvents = () => {
      root.querySelector('.sofia-toggle')?.addEventListener('click', () => {
        isOpen = !isOpen;
        render();
      });
      root.querySelector('.sofia-teaser')?.addEventListener('click', () => {
        isOpen = true;
        render();
      });
      root.querySelector('.sofia-close')?.addEventListener('click', () => {
        isOpen = false;
        render();
      });
      root.querySelector('.sofia-lead')?.addEventListener('submit', submitLead);
      root.querySelectorAll('.sofia-lead input').forEach((input) => {
        input.addEventListener('input', saveLeadFields);
      });
      root.querySelector('.sofia-send')?.addEventListener('click', sendMessage);
      root.querySelector('.sofia-input')?.addEventListener('keydown', (event) => {
        if (event.key === 'Enter') sendMessage();
      });
    };

    render();
  })();
</script>
