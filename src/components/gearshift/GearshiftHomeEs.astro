---
import { defaultHomeEsContent, type HomeEsContent } from '../../data/cms/homeEsContent';

interface Props {
	content?: HomeEsContent;
}

const { content = defaultHomeEsContent } = Astro.props as Props;
const staticContent = defaultHomeEsContent;

const {
	brandName,
	nav,
	hero,
	sections,
	footer,
	whatsappLink,
	locations,
	steps,
	socialLinks,
	metrics
} = staticContent;

const { featuredCarouselItems, offers } = content;

const premiumServices = [
	{
		title: 'Traslados al aeropuerto con chofer privado',
		description:
			'Servicio de pickup y drop-off en aeropuertos de México para viajeros nacionales e internacionales. Coordinamos tu llegada, monitoreamos horarios de vuelo y facilitamos un traslado cómodo hacia hoteles, residencias, centros de negocios o eventos privados.'
	},
	{
		title: 'Renta de camionetas SUV con chofer',
		description:
			'Disponemos de SUVs premium como Chevrolet Suburban, GMC Yukon Denali, Toyota Land Cruiser, Cadillac Escalade y unidades similares para traslados ejecutivos, familiares o turísticos. Ideales para quienes necesitan espacio, comodidad y presencia profesional.'
	},
	{
		title: 'Vehículos blindados en México',
		description:
			'Para clientes que requieren un nivel adicional de protección, ofrecemos opciones de vehículos blindados con chofer, planificación de rutas y coordinación discreta. Este servicio es ideal para ejecutivos, empresarios, artistas, delegaciones y viajeros de alto perfil.'
	},
	{
		title: 'Chofer privado por hora o por día',
		description:
			'Nuestro servicio de chofer privado puede contratarse por traslado, por hora o por día completo, según la agenda del cliente. Es una solución práctica para reuniones de negocios, visitas a clientes, recorridos turísticos, cenas, compras o eventos especiales.'
	}
];

const citySeoBlocks = [
	{ title: 'Chofer privado en Ciudad de México', href: '/es/chofer-privado-cdmx' },
	{ title: 'Transporte premium en Cancún', href: '/es/traslado-aeropuerto-cancun' },
	{ title: 'Renta de SUV con chofer en Guadalajara', href: '/es/chofer-privado-guadalajara' },
	{ title: 'Chofer privado en Monterrey', href: '/es/contact' }
];
---

		<div class="page-wrapper">
			<section>
				<div class="header-section">
					<div class="navbar w-nav">
						<div class="content-wrapper">
								<div class="navbar-wrapper">
										<a href="/es" aria-current="page" class="brand w-nav-brand w--current">
											<span class="brand-logo-text">{brandName}</span>
										</a>
								<nav role="navigation" class="nav-menu-wrapper w-nav-menu">
									<ul role="list" class="nav-menu w-list-unstyled">
											<li class="nav-list-item">
												<a href="/es" aria-current="page" class="nav-link w--current">
													{nav.homeLabel}
												</a>
											</li>
											<li class="nav-list-item">
												<a href="/es/about" class="nav-link">
													{nav.aboutLabel}
												</a>
											</li>
											<li class="nav-list-item">
												<a href="/es/our-fleet" class="nav-link">
													{nav.fleetLabel}
												</a>
											</li>
											<li class="nav-list-item">
												<a href="/es/contact" class="nav-link">
													{nav.contactLabel}
												</a>
											</li>
												<li class="nav-list-item">
													<div class="cta-button-wrapper">
															<a href="/es/our-fleet" class="cta-button w-button">
																{nav.ctaLabel}
															</a>
													</div>
												</li>
												<li class="nav-list-item language-switch-item">
													<div class="language-switch">
														<button
															type="button"
															class="language-switch-button"
															aria-expanded="false"
															aria-label={nav.languageAriaLabel}
														>
															{nav.spanishLabel}
															<span class="language-switch-chevron">v</span>
														</button>
														<div class="language-switch-list">
															<a href="/es" class="language-switch-link active">
																{nav.spanishLabel}
															</a>
															<a href="/" class="language-switch-link">
																{nav.englishLabel}
															</a>
														</div>
													</div>
												</li>
										</ul>
									</nav>
								<button
									type="button"
									class="menu-button w-nav-button"
									aria-label="Abrir menú"
									aria-expanded="false"
								>
									<span class="hamburger-line" ></span>
									<span class="hamburger-line" ></span>
									<span class="hamburger-line" ></span>
								</button>
							</div>
						</div>
					</div>
					<div class="content-wrapper">
						<div class="header-section-wrapper">
							<div class="header-content-wrapper">
									<div class="header-text-wrapper">
											<h1 class="header-text">
										{hero.titleBeforeHighlight} <span class="brand-span">{hero.titleHighlight}</span>
										{hero.titleAfterHighlight ? ` ${hero.titleAfterHighlight}` : ''}
									</h1>
									<div class="primary-text">
										{hero.description}
										</div>
									<div class="header-button-wrapper">
										<a href={hero.ctaHref} class="cta-button w-button">
											{hero.ctaLabel}
										</a>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section class="section bg-white">
				<div class="content-wrapper">
					<div class="section-heading-wrapper">
						<h2 class="section-heading">Transporte privado seguro para viajeros en México</h2>
					</div>
					<p class="primary-text grey-color" style="max-width:980px;margin:0 auto 1rem;">
						Elite Ride Mexico ofrece servicio de transporte privado con chofer en los principales destinos de México. Nos especializamos en traslados al aeropuerto, renta de SUVs premium, movilidad ejecutiva, transporte para familias, grupos privados, eventos corporativos y servicios especiales con vehículos blindados.
					</p>
					<p class="primary-text grey-color" style="max-width:980px;margin:0 auto 2rem;">
						Nuestro servicio está diseñado para viajeros que buscan seguridad, puntualidad, discreción y comodidad desde el primer contacto. Coordinamos cada traslado con anticipación, confirmamos puntos de encuentro, horarios, rutas y necesidades específicas para reducir riesgos y evitar contratiempos durante tu estancia en México.
					</p>
					<div class="grid-wrapper">
						{metrics.map((metric) => (
							<div key={metric.label} class="grid-item-wrapper">
								<div class="metric-number-wrapper">
									<h2 class="metric-number">{metric.value}</h2>
									<h2 class="metric-plus-sign">+</h2>
								</div>
								<div class="title-small">{metric.label}</div>
							</div>
						))}
					</div>
				</div>
			</section>

			{offers.length > 0 && (
				<section class="section">
					<div class="content-wrapper">
						<div class="section-heading-wrapper">
							<h2 class="section-heading">Ofertas Especiales</h2>
						</div>
						<div class="offers-grid">
							{offers.map((offer) => (
								<article key={offer.key} class="offer-card">
									<h3 class="car-listing-name">{offer.title}</h3>
									<p class="primary-text grey-color metric-text">{offer.description}</p>
									<a href={offer.href} class="details-btn w-button">
										{offer.ctaLabel}
									</a>
								</article>
							))}
						</div>
					</div>
				</section>
			)}

			<section class="section">
				<div class="content-wrapper">
					<div class="section-heading-wrapper">
						<h2 class="section-heading">Servicios de transporte premium en México</h2>
					</div>
					<div class="offers-grid">
						{premiumServices.map((service) => (
							<article key={service.title} class="offer-card">
								<h3 class="car-listing-name">{service.title}</h3>
								<p class="primary-text grey-color metric-text">{service.description}</p>
							</article>
						))}
					</div>
				</div>
			</section>

			<section id="featured-cars" class="section">
				<div class="content-wrapper">
					<div class="section-heading-wrapper">
								<h2 class="section-heading">{sections.featuredCarsHeading}</h2>
					</div>
					<div class="cars-collection-list-wrapper featured-cars-carousel" role="region" aria-label="Carrusel de vehículos destacados">
						<div class="featured-cars-carousel__track" aria-live="off">
							<div class="cars-collection-list">
								{featuredCarouselItems.map((item) => (
									<div key={item.key} class="car-collection-item">
										<article class="car-card">
											<a
												href={item.href}
												class="car-image-wrapper w-inline-block"
												target={item.href === whatsappLink ? '_blank' : undefined}
												rel={item.href === whatsappLink ? 'noreferrer' : undefined}
											>
												<picture>
													<source
														srcset={item.image.replace(/\.(jpg|jpeg|png)$/i, '.webp')}
														type="image/webp"
													/>
													<img
														src={item.image}
														loading="lazy"
														decoding="async"
														alt={item.name}
														width={600}
														height={400}
														class="listing-car-image"
													/>
												</picture>
													{item.year ? <div class="car-listing-year">{item.year}</div> : null}
												</a>
												<div class="car-details-wrapper">
													<h3 class="car-listing-name">{item.name}</h3>
												<div class="car-listing-details-wrapper">
													{item.details.map((detail) => (
														<div key={`${item.key}-${detail.key}`} class="car-listing-detail">
															<img src={detail.icon} alt={detail.alt} class="listing-icon" loading="lazy" />
															<div class="listing-detail">{detail.value}</div>
														</div>
													))}
												</div>
												<a
													href={item.href}
													class="details-btn w-button"
													target={item.href === whatsappLink ? '_blank' : undefined}
													rel={item.href === whatsappLink ? 'noreferrer' : undefined}
												>
													{item.ctaLabel}
												</a>
											</div>
										</article>
									</div>
								))}
							</div>
							<div class="cars-collection-list" aria-hidden="true">
								{featuredCarouselItems.map((item) => (
									<div key={`${item.key}-dup`} class="car-collection-item">
										<article class="car-card">
											<a
												href={item.href}
												class="car-image-wrapper w-inline-block"
												tabIndex={-1}
												target={item.href === whatsappLink ? '_blank' : undefined}
												rel={item.href === whatsappLink ? 'noreferrer' : undefined}
											>
												<picture>
													<source
														srcset={item.image.replace(/\.(jpg|jpeg|png)$/i, '.webp')}
														type="image/webp"
													/>
													<img
														src={item.image}
														loading="lazy"
														decoding="async"
														alt=""
														width={600}
														height={400}
														class="listing-car-image"
													/>
												</picture>
												{item.year ? <div class="car-listing-year">{item.year}</div> : null}
											</a>
											<div class="car-details-wrapper">
												<h3 class="car-listing-name">{item.name}</h3>
												<div class="car-listing-details-wrapper">
													{item.details.map((detail) => (
														<div key={`${item.key}-dup-${detail.key}`} class="car-listing-detail">
															<img src={detail.icon} alt="" class="listing-icon" loading="lazy" />
															<div class="listing-detail">{detail.value}</div>
														</div>
													))}
												</div>
												<a
													href={item.href}
													class="details-btn w-button"
													tabIndex={-1}
													target={item.href === whatsappLink ? '_blank' : undefined}
													rel={item.href === whatsappLink ? 'noreferrer' : undefined}
												>
													{item.ctaLabel}
												</a>
											</div>
										</article>
									</div>
								))}
							</div>
						</div>
					</div>
				</div>
			</section>

			<section class="section bg-white">
				<div class="content-wrapper">
					<div class="section-heading-wrapper">
						<h2 class="section-heading">Servicio de chofer privado en las principales ciudades de México</h2>
					</div>
					<p class="primary-text grey-color" style="max-width:980px;margin:0 auto 1.5rem;">
						Operamos traslados privados y renta de vehículos con chofer en CDMX, Cancún, Guadalajara, Monterrey, Puerto Vallarta, Ixtapa Zihuatanejo, León, Cuernavaca y otros destinos bajo solicitud.
					</p>
					<div class="location-collection-list-wrapper">
						<div class="location-collection-list">
							{locations.map((location) => {
								const content = (
									<>
										<img src={location.image} loading="lazy" alt={location.name} class="location-listing-image" />
										<div class="location-name">{location.name}</div>
									</>
								);

								return (
									<div key={location.name} class="location-item">
										{location.href ? (
											<a href={location.href} class="location-listing-image-wrapper w-inline-block">
												{content}
											</a>
										) : (
											<div class="location-listing-image-wrapper w-inline-block location-listing-image-wrapper--static">
												{content}
											</div>
										)}
									</div>
								);
							})}
						</div>
					</div>
					<div class="offers-grid" style="margin-top:1.5rem;">
						{citySeoBlocks.map((city) => (
							<article key={city.title} class="offer-card">
								<h3 class="car-listing-name">{city.title}</h3>
								<a href={city.href} class="details-btn w-button">Ver servicio</a>
							</article>
						))}
					</div>
				</div>
			</section>

			<section class="section">
				<div class="content-wrapper">
					<div class="grid-wrapper">
						{steps.map((step) => (
							<div key={step.title} class="grid-item-wrapper">
								<div class="icon-wrapper">
									<img src={step.icon} loading="lazy" alt={step.alt} />
								</div>
								<div class="title-small">{step.title}</div>
								<div class="primary-text grey-color metric-text">{step.description}</div>
							</div>
						))}
					</div>
				</div>
			</section>

			<section>
				<div class="footer-section-wrapper">
					<div class="content-wrapper">
						<div class="footer-content-wrapper">
								<div class="footer-top-content">
										<div class="footer-logo-social">
											<a href="/es" aria-current="page" class="brand w-nav-brand w--current">
												<span class="brand-logo-text footer-brand-logo-text">{brandName}</span>
											</a>
										<div class="footer-text">
											{footer.description}
										</div>
									<div class="social-media-links">
										{socialLinks.map((social) => (
											<a
												key={social.label}
												href={social.href}
												target="_blank"
												rel="noreferrer"
												class="social-media w-inline-block"
												aria-label={social.label}
											>
												<img src={social.icon} loading="lazy" alt={social.alt} class="image" />
											</a>
										))}
									</div>
								</div>
								<div class="footer-newsletter">
										<h3 class="small-heading">{footer.newsletterTitle}</h3>
									<div class="w-form">
										<form class="newsletter-form">
											<input
												class="form-field w-input"
												maxLength={256}
												name="Email"
												placeholder={footer.newsletterPlaceholder}
												type="email"
												required
											/>
											<input type="submit" class="cta-button w-button" value={footer.newsletterSubmitLabel} />
										</form>
									</div>
								</div>
							</div>
							<div class="divider" />
							<div class="footer-bottom-content">
								<div class="footer-links-wrapper">
										<h2 class="heading">{footer.pagesHeading}</h2>
										{footer.pagesLinks.map((link) => (
											<a href={link.href} class="footer-nav-link">
												{link.label}
											</a>
										))}
								</div>
								<div class="footer-links-wrapper">
									<h2 class="heading">{footer.legalHeading}</h2>
									{footer.legalLinks.map((link) => (
										<a href={link.href} class="footer-nav-link">
											{link.label}
										</a>
									))}
								</div>
								<div class="footer-links-wrapper">
										<h2 class="heading">{footer.contactHeading}</h2>
										{footer.contactLinks.map((link) => (
											<a
												href={link.href}
												target={link.external ? '_blank' : undefined}
												rel={link.external ? 'noreferrer' : undefined}
												class="footer-nav-link"
											>
												{link.label}
											</a>
										))}
								</div>
							</div>
								<div class="divider" />
									<div class="copyright-info-wrapper">
										<a
											href={footer.copyrightHref}
											target="_blank"
											rel="noreferrer"
											class="footer-copyright-text"
										>
											{footer.copyrightText}
										</a>
									</div>
						</div>
					</div>
				</div>
			</section>
			<a
				href={whatsappLink}
				target="_blank"
				rel="noreferrer"
				class="whatsapp-footer-button"
				aria-label="WhatsApp"
			>
				<img
					src="https://cdn.prod.website-files.com/6677ef5c2f59c6148debf7e0/6677ef5c2f59c6148debf814_whatsapp.png"
					loading="lazy"
					alt="WhatsApp Icon"
					class="whatsapp-footer-icon"
				/>
			</a>
		</div>
