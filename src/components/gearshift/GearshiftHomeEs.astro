										</a>
								<nav role="navigation" class="nav-menu-wrapper w-nav-menu">
									<ul role="list" class="nav-menu w-list-unstyled">
											<li class="nav-list-item">
												<a href="/es" aria-current="page" class="nav-link w--current">
													Inicio
												</a>
											</li>
											<li class="nav-list-item">
												<a href="/es/about" class="nav-link">
													Nosotros
												</a>
											</li>
											<li class="nav-list-item">
												<a href="/es/our-fleet" class="nav-link">
													Nuestra Flota
												</a>
											</li>
											<li class="nav-list-item">
												<a href="/es/contact" class="nav-link">
													Contacto
												</a>
											</li>
												<li class="nav-list-item">
													<div class="cta-button-wrapper">
															<a href="/es/our-fleet" class="cta-button w-button">
																Reserva ahora
															</a>
													</div>
												</li>
												<li class="nav-list-item language-switch-item">
													<div class="language-switch">
														<button
															type="button"
															class="language-switch-button"
															aria-expanded="false"
															aria-label="Cambiar idioma"
														>
															ES
															<span class="language-switch-chevron">v</span>
														</button>
														<div class="language-switch-list">
															<a href="/es" class="language-switch-link active">
																ES
															</a>
															<a href="/" class="language-switch-link">
																EN
															</a>
														</div>
													</div>
												</li>
										</ul>
									</nav>
								<button
									type="button"
									class="menu-button w-nav-button"
									aria-label="Toggle menu"
									aria-expanded="false"
								>
									<span class="hamburger-line" ></span>
									<span class="hamburger-line" ></span>
									<span class="hamburger-line" ></span>
								</button>
							</div>
						</div>
					</div>
					<div class="content-wrapper">
						<div class="header-section-wrapper">
							<div class="header-content-wrapper">
									<div class="header-text-wrapper">
											<h1 class="header-text">
										Renta de SUV premium con chofer privado en <span class="brand-span">México</span>
									</h1>
									<div class="primary-text">
										Traslados al aeropuerto, transporte ejecutivo y servicio de chofer privado en Ciudad de México, Cancún, Guadalajara, Puerto Vallarta y más.
										</div>
									<div class="header-button-wrapper">
										<a href="#featured-cars" class="cta-button w-button">
											Ver Nuestra Flota
										</a>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section class="section bg-white">
				<div class="content-wrapper">
					<div class="grid-wrapper">
						{metrics.map((metric) => (
							<div key={metric.label} class="grid-item-wrapper">
								<div class="metric-number-wrapper">
									<h2 class="metric-number">{metric.value}</h2>
									<h2 class="metric-plus-sign">+</h2>
								</div>
								<div class="title-small">{metric.label}</div>
							</div>
						))}
					</div>
				</div>
			</section>

			<section id="featured-cars" class="section">
				<div class="content-wrapper">
					<div class="section-heading-wrapper">
								<h2 class="section-heading">Vehículos Destacados</h2>
					</div>
					<div class="cars-collection-list-wrapper featured-cars-carousel" role="region" aria-label="Carrusel de vehículos destacados">
						<div class="featured-cars-carousel__track" aria-live="off">
							<div class="cars-collection-list">
								{featuredCarouselItems.map((item) => (
									<div key={item.key} class="car-collection-item">
										<article class="car-card">
											<a
												href={item.href}
												class="car-image-wrapper w-inline-block"
												target={item.href === whatsappLink ? '_blank' : undefined}
												rel={item.href === whatsappLink ? 'noreferrer' : undefined}
											>
												<img
													src={item.image}
													loading="lazy"
													decoding="async"
													alt={item.name}
													width={600}
														height={400}
														class="listing-car-image"
													/>
													{item.year ? <div class="car-listing-year">{item.year}</div> : null}
												</a>
												<div class="car-details-wrapper">
													<h3 class="car-listing-name">{item.name}</h3>
												<div class="car-listing-details-wrapper">
													{item.details.map((detail) => (
														<div key={`${item.key}-${detail.key}`} class="car-listing-detail">
															<img src={detail.icon} alt={detail.alt} class="listing-icon" loading="lazy" />
															<div class="listing-detail">{detail.value}</div>
														</div>
													))}
												</div>
												<a
													href={item.href}
													class="details-btn w-button"
													target={item.href === whatsappLink ? '_blank' : undefined}
													rel={item.href === whatsappLink ? 'noreferrer' : undefined}
												>
													{item.ctaLabel}
												</a>
											</div>
										</article>
									</div>
								))}
							</div>
							<div class="cars-collection-list" aria-hidden="true">
								{featuredCarouselItems.map((item) => (
									<div key={`${item.key}-dup`} class="car-collection-item">
										<article class="car-card">
											<a
												href={item.href}
												class="car-image-wrapper w-inline-block"
												tabIndex={-1}
												target={item.href === whatsappLink ? '_blank' : undefined}
												rel={item.href === whatsappLink ? 'noreferrer' : undefined}
											>
												<img
													src={item.image}
													loading="lazy"
													decoding="async"
													alt=""
													width={600}
