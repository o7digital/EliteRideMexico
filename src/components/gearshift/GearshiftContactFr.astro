---

const whatsappLink = 'https://wa.me/525644166523';

const socialLinks = [
	{
		label: 'X',
		href: 'https://x.com/',
		icon: 'https://cdn.prod.website-files.com/6677ef5c2f59c6148debf7e0/6677ef5c2f59c6148debf7f8_twitter.png',
		alt: 'X Icon'
	},
	{
		label: 'Instagram',
		href: 'https://www.instagram.com/',
		icon: 'https://cdn.prod.website-files.com/6677ef5c2f59c6148debf7e0/6677ef5c2f59c6148debf7f9_instagram.png',
		alt: 'Instagram Icon'
	},
	{
		label: 'Facebook',
		href: 'https://www.facebook.com/',
		icon: 'https://cdn.prod.website-files.com/6677ef5c2f59c6148debf7e0/6677ef5c2f59c6148debf7fa_facebook-app-symbol.png',
		alt: 'Facebook Icon'
	},
	{
		label: 'WhatsApp',
		href: whatsappLink,
		icon: 'https://cdn.prod.website-files.com/6677ef5c2f59c6148debf7e0/6677ef5c2f59c6148debf814_whatsapp.png',
		alt: 'WhatsApp Icon'
	}
];

---

		<div class="page-wrapper">
			<section>
				<div class="header-section contact-header-section">
					<div class="navbar w-nav">
						<div class="content-wrapper">
							<div class="navbar-wrapper">
								<a href="/fr" class="brand w-nav-brand">
									<span class="brand-logo-text">ELITE RIDE MEXICO</span>
								</a>
								<nav role="navigation" class="nav-menu-wrapper w-nav-menu">
									<ul role="list" class="nav-menu w-list-unstyled">
										<li class="nav-list-item">
											<a href="/fr" class="nav-link">
												Accueil
											</a>
										</li>
										<li class="nav-list-item">
											<a href="/fr/about" class="nav-link">
												A propos
											</a>
										</li>
											<li class="nav-list-item">
												<a href="/fr/our-fleet" class="nav-link">
													Notre flotte
												</a>
											</li>
											<li class="nav-list-item">
												<a href="/fr/faq" class="nav-link">
													FAQ
											</a>
										</li>
										<li class="nav-list-item">
											<a href="/fr/contact" aria-current="page" class="nav-link w--current">
												Contact
											</a>
										</li>
										<li class="nav-list-item">
											<div class="cta-button-wrapper">
												<a href="/fr/our-fleet" class="cta-button w-button">
													Réserver
													</a>
												</div>
											</li>
											<li class="nav-list-item language-switch-item">
												<div class="language-switch">
													<button
														type="button"
														class="language-switch-button"
														aria-expanded="false"
														aria-label="Changer de langue"
													>
														FR
														<span class="language-switch-chevron">v</span>
													</button>
													<div class="language-switch-list">
														<a href="/fr/contact" class="language-switch-link active">
														FR
													</a>
														<a href="/contact" class="language-switch-link">
														EN
													</a>
													<a href="/es/contact" class="language-switch-link">
														ES
													</a>
													</div>
												</div>
											</li>
										</ul>
								</nav>
								<button
									type="button"
									class="menu-button w-nav-button"
									aria-label="Ouvrir le menu"
									aria-expanded="false"
								>
									<span class="hamburger-line" ></span>
									<span class="hamburger-line" ></span>
									<span class="hamburger-line" ></span>
								</button>
							</div>
						</div>
					</div>
					<div class="content-wrapper">
						<div class="header-section-wrapper">
							<div class="header-content-wrapper">
								<div class="header-text-wrapper contact-header-text-wrapper">
									<h1 class="header-text">Contacter Elite Ride Mexico</h1>
									<div class="primary-text">
										Partagez les détails de votre trajet et notre équipe vous répondra rapidement avec des options de transport privé au Mexique.
									</div>
									<div class="header-button-wrapper">
										<a href={whatsappLink} target="_blank" rel="noreferrer" class="cta-button w-button">
											Nous écrire sur WhatsApp
										</a>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section class="section bg-white">
				<div class="content-wrapper">
					<div class="contact-layout">
						<div class="contact-form-card">
							<h2 class="section-heading">Envoyez votre demande</h2>
							<p class="primary-text grey-color">
								Usa este formulario para solicitar traslado al aeropuerto, viaje interurbano, chofer privado o
								transporte blindado.
							</p>
							<div class="w-form">
								<form
									class="contact-form"
									action="https://formspree.io/f/xqednlel"
									method="POST"
								>
									<div class="contact-field-row">
										<input
											class="form-field w-input"
											name="full_name"
											placeholder="Nom complet"
											type="text"
											required
										/>
										<input
											class="form-field w-input"
											name="phone"
											placeholder="Téléphone / WhatsApp"
											type="tel"
											required
										/>
									</div>
									<div class="contact-field-row">
										<input
											class="form-field w-input"
											name="email"
											placeholder="Email"
											type="email"
											required
										/>
										<input
											class="form-field w-input"
											name="country"
											placeholder="Pays"
											type="text"
											required
										/>
									</div>
									<div class="contact-field-row">
										<input
											class="form-field w-input"
											name="travel_dates"
											placeholder="Date(s) de voyage"
											type="text"
										/>
										<select class="form-field w-input contact-select" name="service_type" required>
											<option value="" disabled>
												Type de service
											</option>
											<option value="airport-transfer">Transfert aéroport</option>
											<option value="private-driver">Chauffeur privé</option>
											<option value="armored-vehicle">Véhicule blindé</option>
											<option value="intercity-trip">Trajet interurbain</option>
										</select>
									</div>
									<textarea
										class="form-field w-input contact-textarea"
										name="message"
										placeholder="Indiquez votre itinéraire, la ville, le point de prise en charge et le nombre de passagers."
										required
									></textarea>
									<input type="hidden" name="_subject" value="Nueva solicitud de contacto - Elite Ride Mexico" />
									<input type="submit" class="cta-button w-button contact-submit" value="Envoyer la demande" />
								</form>
							</div>
						</div>
						<div class="contact-info-stack">
							<div class="contact-info-card">
								<h3 class="title-small">WhatsApp</h3>
								<a href={whatsappLink} target="_blank" rel="noreferrer" class="footer-nav-link">
									+52 5644166523
								</a>
							</div>
							<div class="contact-info-card">
								<h3 class="title-small">Email</h3>
								<a href="mailto:info@eliteridemexico.com" class="footer-nav-link">
									info@eliteridemexico.com
								</a>
							</div>
							<div class="contact-info-card">
								<h3 class="title-small">Oficina</h3>
								<p class="primary-text grey-color metric-text">
									Goldsmith 250, Lomas de Chapultepec, Miguel Hidalgo, 11500, CDMX, México.
								</p>
							</div>
							<div class="contact-info-card">
								<h3 class="title-small">Tiempo de respuesta</h3>
								<p class="primary-text grey-color metric-text">
									Normalmente respondemos en 15–30 minutos durante horario de operación.
								</p>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section>
				<div class="footer-section-wrapper">
					<div class="content-wrapper">
						<div class="footer-content-wrapper">
							<div class="footer-top-content">
								<div class="footer-logo-social">
									<a href="/fr" class="brand w-nav-brand">
										<span class="brand-logo-text footer-brand-logo-text">ELITE RIDE MEXICO</span>
									</a>
									<div class="footer-text">
										Transport premium avec chauffeur pour les voyageurs qui privilégient sécurité, ponctualité et service
										local de confianza.
									</div>
									<div class="social-media-links">
										{socialLinks.map((social) => (
											<a
												key={social.label}
												href={social.href}
												target="_blank"
												rel="noreferrer"
												class="social-media w-inline-block"
												aria-label={social.label}
											>
												<img src={social.icon} loading="lazy" alt={social.alt} class="image" />
											</a>
										))}
									</div>
								</div>
								<div class="footer-newsletter">
									<h3 class="small-heading">Suscríbete a nuestro boletín</h3>
									<div class="w-form">
										<form class="newsletter-form">
											<input
												class="form-field w-input"
												maxLength={256}
												name="Email"
												placeholder="example@gmail.com"
												type="email"
												required
											/>
											<input type="submit" class="cta-button w-button" value="Enviar" />
										</form>
									</div>
								</div>
							</div>
							<div class="divider" />
							<div class="footer-bottom-content">
								<div class="footer-links-wrapper">
									<h2 class="heading">Pages</h2>
									<a href="/fr" class="footer-nav-link">
										Accueil
									</a>
									<a href="/fr/about" class="footer-nav-link">
										A propos
									</a>
									<a href="/fr/our-fleet" class="footer-nav-link">
										Notre flotte
									</a>
									<a href="/fr/contact" aria-current="page" class="footer-nav-link w--current">
										Contact
									</a>
								</div>
								<div class="footer-links-wrapper">
									<h2 class="heading">Legal</h2>
										<a href="/fr/aviso-de-privacidad" class="footer-nav-link">
											Aviso de Privacidad
										</a>
										<a href="/fr/cancelacion" class="footer-nav-link">
											Annulation
										</a>
										<a href="/fr/reembolsos" class="footer-nav-link">
											Remboursements
										</a>
										<a href="/fr/impuestos" class="footer-nav-link">
											Taxes
										</a>
								</div>
								<div class="footer-links-wrapper">
									<h2 class="heading">Contáctanos</h2>
									<a href="tel:+525644166523" class="footer-nav-link">
										+52 5644166523
									</a>
									<a href="mailto:info@eliteridemexico.com" class="footer-nav-link">
										info@eliteridemexico.com
									</a>
									<a
										href="https://www.google.com/maps/search/Goldsmith+250,+Lomas+de+Chapultepec,+Ciudad+de+Mexico"
										target="_blank"
										rel="noreferrer"
										class="footer-nav-link"
									>
										Goldsmith 250, Lomas de Chapultepec, Miguel Hidalgo, 11500, CDMX, México.
									</a>
								</div>
							</div>
							<div class="divider" />
							<div class="copyright-info-wrapper">
								<a
									href="https://www.o7digital.com/en/index-digital-agency"
									target="_blank"
									rel="noreferrer"
									class="footer-copyright-text"
								>
									Copyright Elite Ride Mexico 2026 - hecho por o7Digital
								</a>
							</div>
						</div>
					</div>
				</div>
			</section>
			<a href={whatsappLink} target="_blank" rel="noreferrer" class="whatsapp-footer-button" aria-label="WhatsApp">
				<img
					src="https://cdn.prod.website-files.com/6677ef5c2f59c6148debf7e0/6677ef5c2f59c6148debf814_whatsapp.png"
					loading="lazy"
					alt="WhatsApp Icon"
					class="whatsapp-footer-icon"
				/>
			</a>
		</div>
