													aria-expanded="false"
													aria-label="Switch language"
												>
													FR
															<span class="language-switch-chevron">v</span>
												</button>
												<div class="language-switch-list">
													<a href="/" class="language-switch-link">
															EN
														</a>
													<a href="/es" class="language-switch-link">
														ES
													</a>
													<a href="/fr" class="language-switch-link active">
															FR
														</a>
												</div>
											</div>
