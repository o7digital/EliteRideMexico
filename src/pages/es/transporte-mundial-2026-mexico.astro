---
import Layout from '../../layouts/Layout.astro';
import { getWorldCupKeywordLines } from '../../data/worldCupKeywords';

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Ofrecen traslados privados para la Copa del Mundo FIFA 2026 en México?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí. Elite Ride Mexico ofrece traslados privados con chofer para visitantes de la Copa del Mundo FIFA 2026, incluyendo aeropuerto, hotel y movilidad para días de partido.'
      }
    },
    {
      '@type': 'Question',
      name: '¿Puedo reservar transporte al Estadio Azteca?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí. Organizamos traslados privados al Estadio Azteca con chofer bilingüe, horarios flexibles y logística de regreso.'
      }
    },
    {
      '@type': 'Question',
      name: '¿Cómo reservo un traslado para México 2026?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Escríbenos por WhatsApp al +52 5644166523 con fecha, origen y número de pasajeros. Confirmamos disponibilidad rápidamente.'
      }
    }
  ]
});

const whatsappLink = 'https://wa.me/525644166523';
const keywordLines = getWorldCupKeywordLines('es');
---

<Layout
  title="Transporte Privado para Mundial 2026 en México | Elite Ride Mexico"
  description="Reserva transporte privado con chofer para el Mundial 2026 en México. SUVs premium, traslados al aeropuerto, servicio al Estadio Azteca, Guadalajara y Monterrey, atención bilingüe y vehículos blindados bajo solicitud."
  canonicalURL="https://eliteridemexico.com/es/transporte-mundial-2026-mexico"
  preloadImages={['/contact/cdmx-timeout.webp']}
  lang="es"
  alternateHref="https://eliteridemexico.com/world-cup-2026-mexico"
  alternateLang="en"
>
  <script type="application/ld+json" slot="head" set:html={faqSchema} />

  <div class="page-wrapper">
    <section>
      <div class="header-section contact-header-section">
        <div class="navbar w-nav">
          <div class="content-wrapper">
            <div class="navbar-wrapper">
              <a href="/es" class="brand w-nav-brand">
                <span class="brand-logo-text">ELITE RIDE MEXICO</span>
              </a>
              <nav role="navigation" class="nav-menu-wrapper w-nav-menu">
                <ul role="list" class="nav-menu w-list-unstyled">
                  <li class="nav-list-item"><a href="/es" class="nav-link">Inicio</a></li>
                  <li class="nav-list-item"><a href="/es/about" class="nav-link">Nosotros</a></li>
                  <li class="nav-list-item"><a href="/es/our-fleet" class="nav-link">Nuestra Flota</a></li>
                  <li class="nav-list-item"><a href="/es/contact" class="nav-link">Contacto</a></li>
                  <li class="nav-list-item">
                    <div class="cta-button-wrapper">
                      <a href="/es/our-fleet" class="cta-button w-button">Reservar ahora</a>
                    </div>
                  </li>
                </ul>
              </nav>
            </div>
          </div>
        </div>

        <div class="content-wrapper">
          <div class="header-section-wrapper">
            <div class="header-content-wrapper">
              <div class="header-text-wrapper contact-header-text-wrapper">
                <h1 class="header-text">Transporte privado para el Mundial 2026 en México</h1>
                <div class="primary-text">
                  Elite Ride Mexico ofrece transporte privado con chofer para aficionados, familias, directivos, patrocinadores, delegaciones y viajeros internacionales que visitan México durante el Mundial 2026.
                </div>
                <div class="header-button-wrapper">
                  <a href={whatsappLink} target="_blank" rel="noreferrer" class="cta-button w-button">
                    Reservar por WhatsApp
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section bg-white">
      <div class="content-wrapper">
        <h2 class="section-heading">Traslados privados para el torneo en México</h2>
        <p class="primary-text grey-color" style="max-width:760px;margin:0 auto 1.5rem;">
          Ofrecemos traslados al aeropuerto, transporte hacia estadios, servicio por día completo, SUVs premium, camionetas para grupos y opciones de vehículos blindados bajo solicitud en Ciudad de México, Guadalajara y Monterrey.
        </p>

        <h2 class="section-heading" style="margin-top:2.5rem;">Traslados al Estadio Azteca / Estadio Ciudad de México</h2>
        <div class="grid-wrapper" style="margin-top:1.5rem;">
          <div class="grid-item-wrapper">
            <h3 class="title-small">Operación para día de partido</h3>
            <p class="primary-text grey-color metric-text">
              Coordinamos traslados privados desde hoteles, aeropuertos, zonas residenciales y puntos corporativos hacia el Estadio Ciudad de México, con rutas planificadas, horarios definidos y soporte por WhatsApp durante el servicio.
            </p>
          </div>
          <div class="grid-item-wrapper">
            <h3 class="title-small">Transporte para partidos en Guadalajara y Monterrey</h3>
            <p class="primary-text grey-color metric-text">
              También ofrecemos movilidad privada para viajeros que asistirán a partidos en Guadalajara y Monterrey, incluyendo pickups en aeropuerto, traslados a hoteles, servicio por hora, camionetas para grupos y coordinación para varios días.
            </p>
          </div>
          <div class="grid-item-wrapper">
            <h3 class="title-small">Reserva tu transporte antes del torneo</h3>
            <p class="primary-text grey-color metric-text">
              Durante eventos internacionales, la disponibilidad de transporte premium puede reducirse rápidamente. Recomendamos reservar con anticipación para asegurar unidad, chofer y coordinación de ruta.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="content-wrapper">
        <h2 class="section-heading">Búsquedas frecuentes para México 2026</h2>
        <p class="primary-text grey-color seo-keywords-intro">
          Los viajeros que vienen al torneo suelen buscar traslados al aeropuerto, chofer privado, transporte al
          estadio, movilidad ejecutiva, SUVs premium, rutas seguras y servicio VIP entre las principales sedes.
        </p>
        <div class="seo-content-keywords">
          {keywordLines.map((line) => (
            <p class="seo-content-keywords__line">{line}</p>
          ))}
        </div>

        <h2 class="section-heading" style="margin-top:2.5rem;">Preguntas Frecuentes</h2>
        <div class="grid-wrapper" style="margin-top:1.5rem;">
          <div class="grid-item-wrapper">
            <h3 class="title-small">¿Ofrecen traslados para la Copa del Mundo FIFA 2026 en México?</h3>
            <p class="primary-text grey-color metric-text">
              Sí. Atendemos traslados privados para visitantes en CDMX y otros destinos estratégicos.
            </p>
          </div>
          <div class="grid-item-wrapper">
            <h3 class="title-small">¿Puedo reservar transporte al Estadio Azteca?</h3>
            <p class="primary-text grey-color metric-text">
              Sí. Comparte fecha de partido y punto de salida para organizar tu plan de traslado.
            </p>
          </div>
          <div class="grid-item-wrapper">
            <h3 class="title-small">¿Cómo reservo?</h3>
            <p class="primary-text grey-color metric-text">
              Escríbenos por WhatsApp al +52 5644166523. Respondemos rápido con disponibilidad y tarifa.
            </p>
          </div>
          <div class="grid-item-wrapper">
            <h3 class="title-small">¿Atienden grupos y ejecutivos?</h3>
            <p class="primary-text grey-color metric-text">
              Sí. Diseñamos itinerarios para grupos, ejecutivos y perfiles VIP con chofer dedicado.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section bg-white">
      <div class="content-wrapper" style="text-align:center;">
        <h2 class="section-heading">Planea tu movilidad para México 2026</h2>
        <p class="primary-text grey-color" style="max-width:620px;margin:0 auto 1.5rem;">
          En eventos FIFA la demanda sube rápidamente. Reserva con anticipación para asegurar disponibilidad.
        </p>
        <a href={whatsappLink} target="_blank" rel="noreferrer" class="cta-button w-button">WhatsApp</a>
        <span style="display:inline-block;width:1rem;"></span>
        <a href="/es/contact" class="cta-button w-button" style="background:#333;">Enviar solicitud</a>
      </div>
    </section>
  </div>
</Layout>
