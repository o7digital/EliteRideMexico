---
import GearshiftHomeEs from '../../components/gearshift/GearshiftHomeEs.astro';
import Layout from '../../layouts/Layout.astro';
import { getHomeEsContent } from '../../lib/cms/homeEs';

const homeContent = await getHomeEsContent();

const seo = {
	title: homeContent.seo.title,
	description: homeContent.seo.description,
	canonicalURL: homeContent.seo.canonicalUrl,
	ogImage: homeContent.seo.ogImage
};
---

<Layout
	title={seo.title}
	description={seo.description}
	canonicalURL={seo.canonicalURL}
	ogImage={seo.ogImage}
	lang="es"
	preloadImages={['/slider/gemini-bmw.webp']}
	alternateHref="https://eliteridemexico.com/"
	alternateLang="en"
>
	<GearshiftHomeEs content={homeContent} />
</Layout>
