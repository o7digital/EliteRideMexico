---
import LegalPageTemplate from '../components/LegalPageTemplate.astro';
import { legalPagesEn, type LegalPageContent } from '../data/legalPages';

export function getStaticPaths() {
	return legalPagesEn.map((page) => ({
		params: { legal: page.slug },
		props: { page }
	}));
}

const { page } = Astro.props as { page: LegalPageContent };
const canonicalURL = `https://eliteridemexico.com/${page.slug}`;
const alternateHref = `https://eliteridemexico.com/es/${page.alternateSlug}`;
---

<LegalPageTemplate
	title={page.title}
	description={page.description}
	heading={page.heading}
	intro={page.intro}
	sections={page.sections}
	canonicalURL={canonicalURL}
	alternateHref={alternateHref}
	alternateLang="es"
/>
